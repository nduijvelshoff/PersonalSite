---
import '@fortawesome/fontawesome-free/css/all.min.css';

interface Props {
  title: string;
  description?: string;
  minimal?: boolean;
}

const { title, description = "Nick Duijvelshoff - Enabling Awesomeness", minimal = false } = Astro.props;
const siteName = "Nick Duijvelshoff";
const fullTitle = title === siteName ? siteName : `${title} | ${siteName}`;
const pathname = Astro.url.pathname;

const socialLinks = [
  { name: "GitHub", url: "https://github.com/nduijvelshoff" },
  { name: "LinkedIn", url: "https://linkedin.com/in/nduijvelshoff" },
  { name: "Instagram", url: "https://instagram.com/nduijvelshoff" },
  { name: "Medium", url: "https://medium.com/@nduijvelshoff" },
  { name: "Keybase", url: "https://keybase.io/nduijvelshoff" },
  { name: "Spotify", url: "https://open.spotify.com/user/nduijvelshoff" },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;700;800&family=Newsreader:opsz,wght@6..72,500;6..72,700&family=Roboto:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --bg: #fffaf2;
        --bg-soft: #fff2dd;
        --paper: #fffdf8;
        --ink: #1b1e2e;
        --muted: #5e6473;
        --line: #e5d8c3;
        --brand: #0f766e;
        --brand-strong: #0a5b55;
        --shadow: 0 20px 45px rgba(32, 35, 48, 0.09);
      }

      body {
        font-family: "Manrope", "Avenir Next", "Segoe UI", sans-serif;
        line-height: 1.6;
        color: var(--ink);
        background: linear-gradient(180deg, #fffdf9 0%, #fffaf2 100%);
        min-height: 100vh;
        overflow-x: hidden;
      }

      body.minimal {
        position: fixed;
        inset: 0;
        width: 100%;
        min-height: 100svh;
        min-height: 100dvh;
        overflow: hidden;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      a {
        color: var(--brand);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: "Newsreader", Georgia, serif;
        line-height: 1.1;
        letter-spacing: -0.02em;
      }
    </style>
  </head>
  <body class={minimal ? "minimal" : undefined}>
    <div class="page-shell">
      <div class="container">
      {!minimal && (
        <header class="header">
          <nav class="nav">
            <div class="nav-brand">
              <a href="/">Nick Duijvelshoff</a>
            </div>
            <ul class="nav-links">
              <li><a href="/#home" class={pathname === "/" ? "active" : undefined}>Home</a></li>
              <li><a href="/#focus" class={pathname === "/" ? "active" : undefined}>Focus</a></li>
              <li><a href="/#about" class={pathname === "/" ? "active" : undefined}>About</a></li>
            </ul>
          </nav>
        </header>
      )}

      <main class="main">
        <slot />
      </main>

      {!minimal && (
        <footer class="footer">
          <div class="social-links">
            {socialLinks.map((link) => (
              <a href={link.url} target="_blank" rel="noopener noreferrer" title={link.name}>
                {link.name}
              </a>
            ))}
          </div>
          <p>&copy; 2022-{new Date().getFullYear()} Nick Duijvelshoff. Enabling Awesomeness.</p>
        </footer>
      )}
      </div>
    </div>

    <style>
      .page-shell {
        position: relative;
        overflow: hidden;
      }

      .minimal .page-shell {
        width: 100%;
        min-height: 100svh;
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .container {
        max-width: 900px;
        margin: 28px auto;
        padding: 0 22px;
      }

      .header {
        padding: 16px 22px;
        border: 1px solid var(--line);
        background: rgba(255, 253, 248, 0.8);
        backdrop-filter: blur(8px);
        border-radius: 18px;
        margin-bottom: 34px;
        box-shadow: var(--shadow);
      }

      .nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .nav-brand a {
        font-size: 22px;
        font-weight: 800;
        color: var(--ink);
        text-decoration: none;
      }

      .nav-links {
        display: flex;
        list-style: none;
        gap: 14px;
      }

      .nav-links a {
        color: var(--muted);
        transition: all 0.2s ease;
        text-decoration: none;
        padding: 8px 12px;
        border-radius: 999px;
        font-weight: 600;
      }

      .nav-links a:hover {
        color: var(--brand);
        background: #f0fbf9;
        text-decoration: none;
      }

      .nav-links a.active {
        color: var(--brand-strong);
        background: #def3ee;
      }

      .main {
        min-height: 60vh;
        margin-bottom: 40px;
      }

      .minimal .main {
        min-height: auto;
        height: auto;
        margin-bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
      }

      .minimal .container {
        margin: 0;
        min-height: auto;
        height: auto;
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .footer {
        border-top: 1px solid var(--line);
        padding-top: 30px;
        padding-bottom: 30px;
        text-align: center;
        color: var(--muted);
        font-size: 14px;
      }

      .social-links {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-bottom: 20px;
        flex-wrap: wrap;
      }

      .social-links a {
        color: var(--muted);
        transition: all 0.2s ease;
        border: 1px solid var(--line);
        border-radius: 999px;
        padding: 7px 11px;
        background: rgba(255, 255, 255, 0.45);
      }

      .social-links a:hover {
        color: var(--brand);
        border-color: #bbdccc;
        background: #f2fbf9;
        text-decoration: none;
      }

      @media (max-width: 760px) {
        .nav {
          flex-direction: column;
          gap: 15px;
        }

        .nav-links {
          gap: 8px;
          flex-wrap: wrap;
          justify-content: center;
        }

        .container {
          margin-top: 18px;
        }

        .header {
          margin-bottom: 26px;
        }

        .minimal .container {
          margin-top: 0;
        }
      }
    </style>
  </body>
</html>
