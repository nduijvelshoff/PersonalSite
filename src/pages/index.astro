---
import BaseLayout from '../layouts/BaseLayout.astro';

const profileImageUrl = "/profile.jpg";
const backgroundVideoUrl = "/bg-sea.mp4";

const socialLinks = [
  { name: "GitHub", iconClass: "fa-brands fa-github", url: "https://github.com/nduijvelshoff" },
  { name: "LinkedIn", iconClass: "fa-brands fa-linkedin", url: "https://linkedin.com/in/nduijvelshoff" },
  { name: "Instagram", iconClass: "fa-brands fa-instagram", url: "https://instagram.com/nduijvelshoff" },
  { name: "Medium", iconClass: "fa-brands fa-medium", url: "https://medium.com/@nduijvelshoff" },
  { name: "Spotify", iconClass: "fa-brands fa-spotify", url: "https://open.spotify.com/user/nduijvelshoff" },
];
---

<BaseLayout title="Nick Duijvelshoff" description="Personal site of Nick Duijvelshoff" minimal={true}>
  <div class="video-bg" aria-hidden="true">
    <video
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      onloadedmetadata="this.playbackRate = 0.7; this.defaultPlaybackRate = 0.7;"
    >
      <source src={backgroundVideoUrl} type="video/mp4" />
    </video>
  </div>
  <div class="video-overlay" aria-hidden="true"></div>

  <section class="single-profile" aria-label="Profile">
    <div class="photo-card">
      <img src={profileImageUrl} alt="Nick Duijvelshoff" class="avatar" />
      <h1>
        <span class="title-group">
          <span class="name-text">Nick Duijvelshoff</span>
          <span class="motto">Enabling Awesomeness since 1987</span>
        </span>
      </h1>
      <div class="social-links" aria-label="Social links">
        {socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.name} title={link.name}>
            <i class={link.iconClass} aria-hidden="true"></i>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .video-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .video-bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-overlay {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(180deg, rgba(7, 12, 22, 0.28) 0%, rgba(8, 10, 16, 0.45) 100%);
  }

  .single-profile {
    width: min(560px, 100%);
    margin: 0 auto;
    text-align: center;
    position: relative;
    z-index: 2;
  }

  .photo-card {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--shadow);
    margin-bottom: 16px;
  }

  .avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  h1 {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 52px;
    display: grid;
    justify-items: center;
    color: #ffffff;
    font-size: clamp(2rem, 6vw, 2.9rem);
    margin: 0;
    padding: 56px 20px 10px;
    background: linear-gradient(180deg, rgba(10, 10, 10, 0) 0%, rgba(10, 10, 10, 0.68) 72%);
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.38);
    z-index: 2;
  }

  .title-group {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
  }

  .name-text {
    line-height: 1;
  }

  .social-links {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 9.5px;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    z-index: 3;
    padding: 0 12px;
  }

  .motto {
    font-family: "Elms Sans", "Roboto", "Segoe UI", sans-serif;
    color: #ffffff;
    font-size: 0.3em;
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1;
    margin-bottom: 0;
    white-space: nowrap;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.45);
    opacity: 0.95;
  }

  .social-links a {
    width: 34px;
    height: 34px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    transition: all 0.2s ease;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 10px;
    background: rgba(10, 10, 10, 0.34);
    font-weight: 600;
    text-decoration: none;
    backdrop-filter: blur(3px);
  }

  .social-links a i {
    font-size: 1rem;
    line-height: 1;
  }

  .social-links a:hover {
    color: #ffffff;
    border-color: rgba(255, 255, 255, 0.62);
    background: rgba(10, 10, 10, 0.5);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .photo-card {
      border-radius: 10px;
    }
  }
</style>
